# ─── Base de données ────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/stream_overlay"

# ─── Bot Discord ─────────────────────────────────────────────────────────────
DISCORD_TOKEN="votre_token_bot"
DISCORD_CLIENT_ID="votre_application_client_id"

# ─── OAuth Discord (requis uniquement en mode cloud) ─────────────────────────
DISCORD_CLIENT_SECRET="votre_client_secret"

# ─── Mode ────────────────────────────────────────────────────────────────────
# "self-hosted" : une seule room locale, pas d'auth Discord requise
# "cloud"       : multi-utilisateurs avec login Discord OAuth
MODE="self-hosted"

# ─── Serveur HTTP ────────────────────────────────────────────────────────────
PORT=3000
HOST=0.0.0.0

# ─── URLs ────────────────────────────────────────────────────────────────────
# En self-hosted : http://localhost:3000
# En cloud       : votre URL Cloudflare Tunnel ou VPS
PUBLIC_URL="http://localhost:3000"

# URL du frontend Qwik (Vercel en prod, localhost en dev)
FRONTEND_URL="http://localhost:5173"

# ─── Sécurité session ────────────────────────────────────────────────────────
SESSION_SECRET="changez-moi-en-production-avec-une-vraie-clé-aléatoire"
