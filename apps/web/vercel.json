{
  "headers": [
    {
      "source": "/(.*)?service-worker.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/(assets|build)/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, s-maxage=31536000, immutable"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://fin-december-kit-concept.trycloudflare.com/api/:path*"
    },
    {
      "source": "/auth/:path*",
      "destination": "https://fin-december-kit-concept.trycloudflare.com/auth/:path*"
    }
  ]
}